# Set one of these — the app auto-detects which provider to use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Upstash Redis (optional — enables daily hot cache, app works without it)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# FalkorDB (optional — enables persistent graph storage + cross-day relations)
# FALKORDB_HOST=localhost
# FALKORDB_PORT=6379
# FALKORDB_USERNAME=
# FALKORDB_PASSWORD=
