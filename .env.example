# LLM provider — set one of these, the app auto-detects which to use
ANTHROPIC_API_KEY=
# Always required — used for embeddings (dedup + relation detection)
OPENAI_API_KEY=

# Upstash Redis (optional — enables daily hot cache, app works without it)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# FalkorDB (optional — enables persistent graph storage + cross-day relations)
# FALKORDB_HOST=localhost
# FALKORDB_PORT=6379
# FALKORDB_USERNAME=
# FALKORDB_PASSWORD=

# Vercel Cron (required for scheduled news refresh)
# CRON_SECRET=
